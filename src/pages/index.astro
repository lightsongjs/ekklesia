---
import ServiceLayout from "../layouts/ServiceLayout.astro";
import { getAllSaturdays, getPresanctifiedDays } from "../lib/context";

const year = 2026;
const saturdays = getAllSaturdays(year);
const presanctifiedDays = getPresanctifiedDays(year);

function toISODate(d: Date): string {
  return d.toISOString().split("T")[0];
}

// Build lookup maps: ISO date → link info
interface DayInfo {
  href: string;
  type: "vecernie" | "presanctified";
  label: string;
  tone?: number;
}

const dayMap = new Map<string, DayInfo>();

for (const sat of saturdays) {
  const iso = toISODate(sat.date);
  const label = sat.lentWeek > 0
    ? sat.sundayName
    : `Glasul ${sat.tone}`;
  dayMap.set(iso, {
    href: `/vespers/${iso}`,
    type: "vecernie",
    label,
    tone: sat.tone,
  });
}

for (const day of presanctifiedDays) {
  const iso = toISODate(day.date);
  dayMap.set(iso, {
    href: `/presanctified/${iso}`,
    type: "presanctified",
    label: `Săpt. ${day.lentWeek}`,
    tone: day.tone,
  });
}

// Romanian month names
const MONTHS_RO = [
  "Ianuarie", "Februarie", "Martie", "Aprilie",
  "Mai", "Iunie", "Iulie", "August",
  "Septembrie", "Octombrie", "Noiembrie", "Decembrie",
];

const DAY_HEADERS = ["Lu", "Ma", "Mi", "Jo", "Vi", "Sâ", "Du"];

// Build calendar data for each month
interface CalendarDay {
  day: number;
  iso: string;
  info?: DayInfo;
}

interface MonthData {
  month: number; // 0-based
  name: string;
  days: (CalendarDay | null)[][]; // weeks, null = empty cell
}

function buildMonth(month: number): MonthData {
  const firstDay = new Date(Date.UTC(year, month, 1));
  const daysInMonth = new Date(Date.UTC(year, month + 1, 0)).getUTCDate();

  // Monday=0 offset for first day
  let startDow = firstDay.getUTCDay(); // 0=Sun
  startDow = startDow === 0 ? 6 : startDow - 1; // Convert to Mon=0

  const weeks: (CalendarDay | null)[][] = [];
  let week: (CalendarDay | null)[] = [];

  // Leading empty cells
  for (let i = 0; i < startDow; i++) {
    week.push(null);
  }

  for (let d = 1; d <= daysInMonth; d++) {
    const iso = `${year}-${String(month + 1).padStart(2, "0")}-${String(d).padStart(2, "0")}`;
    const info = dayMap.get(iso);
    week.push({ day: d, iso, info });

    if (week.length === 7) {
      weeks.push(week);
      week = [];
    }
  }

  // Trailing empty cells
  if (week.length > 0) {
    while (week.length < 7) {
      week.push(null);
    }
    weeks.push(week);
  }

  return { month, name: MONTHS_RO[month], days: weeks };
}

const months: MonthData[] = Array.from({ length: 12 }, (_, i) => buildMonth(i));
---

<ServiceLayout title="Slujbele Anului 2026">
  <div class="print:hidden">
    {/* Month navigation */}
    <div class="flex items-center justify-between mb-6">
      <button
        id="prev-month"
        class="text-stone-500 hover:text-rubric text-2xl px-3 py-1 select-none"
        aria-label="Luna precedentă"
      >&larr;</button>
      <h2 id="month-title" class="text-xl font-semibold"></h2>
      <button
        id="next-month"
        class="text-stone-500 hover:text-rubric text-2xl px-3 py-1 select-none"
        aria-label="Luna următoare"
      >&rarr;</button>
    </div>

    {/* Legend */}
    <div class="flex flex-wrap gap-4 justify-center mb-6 text-sm text-stone-500">
      <span class="flex items-center gap-1.5">
        <span class="inline-block w-3 h-3 rounded-sm bg-red-700/15 border border-red-700/30"></span>
        Vecernie (Sâmbătă)
      </span>
      <span class="flex items-center gap-1.5">
        <span class="inline-block w-3 h-3 rounded-sm bg-amber-600/15 border border-amber-600/30"></span>
        Liturghia Darurilor (Mi/Vi Post)
      </span>
    </div>

    {/* Calendar months */}
    {months.map((m) => (
      <div
        class="calendar-month hidden"
        data-month={m.month}
      >
        {/* Day headers */}
        <div class="grid grid-cols-7 gap-1 mb-1">
          {DAY_HEADERS.map((dh, i) => (
            <div class:list={[
              "text-center text-xs font-semibold uppercase tracking-wide py-1",
              i === 5 ? "text-rubric" : "text-stone-400",
              i === 6 ? "text-rubric/60" : "",
            ]}>
              {dh}
            </div>
          ))}
        </div>

        {/* Weeks */}
        {m.days.map((week) => (
          <div class="grid grid-cols-7 gap-1">
            {week.map((cell) => {
              if (!cell) {
                return <div class="h-14 sm:h-16" />;
              }
              if (cell.info) {
                const isVec = cell.info.type === "vecernie";
                return (
                  <a
                    href={cell.info.href}
                    class:list={[
                      "h-14 sm:h-16 rounded-lg flex flex-col items-center justify-center transition-all hover:shadow-md group relative",
                      isVec
                        ? "bg-red-700/10 hover:bg-red-700/20 border border-red-700/20 hover:border-red-700/40"
                        : "bg-amber-600/10 hover:bg-amber-600/20 border border-amber-600/20 hover:border-amber-600/40",
                    ]}
                    title={cell.info.label}
                  >
                    <span class:list={[
                      "text-sm font-semibold",
                      isVec ? "text-red-800" : "text-amber-800",
                    ]}>
                      {cell.day}
                    </span>
                    <span class:list={[
                      "text-[10px] leading-tight truncate max-w-full px-0.5",
                      isVec ? "text-red-700/70" : "text-amber-700/70",
                    ]}>
                      {cell.info.tone ? `gl.${cell.info.tone}` : ""}
                    </span>
                  </a>
                );
              }
              return (
                <div class="h-14 sm:h-16 flex items-center justify-center">
                  <span class="text-sm text-stone-400">{cell.day}</span>
                </div>
              );
            })}
          </div>
        ))}
      </div>
    ))}

    {/* Quick list for Lent (below calendar) */}
    <details class="mt-10 border border-stone-200 rounded-lg">
      <summary class="px-5 py-3 cursor-pointer text-stone-600 hover:text-rubric font-medium">
        Lista completă — Postul Mare 2026
      </summary>
      <div class="p-5 pt-2 space-y-6">
        <div>
          <h3 class="font-semibold text-stone-700 mb-2">Vecernia Mare (Sâmbetele)</h3>
          <div class="space-y-2">
            {saturdays.filter(s => s.lentWeek > 0).map((sat) => (
              <a
                href={`/vespers/${toISODate(sat.date)}`}
                class="block text-sm hover:text-rubric transition-colors"
              >
                <span class="text-stone-500">{sat.formattedDate}</span>
                <span class="mx-1">·</span>
                <span class="text-rubric">{sat.sundayName}</span>
                <span class="text-stone-400 ml-1">(gl. {sat.tone})</span>
              </a>
            ))}
          </div>
        </div>
        <div>
          <h3 class="font-semibold text-stone-700 mb-2">Liturghia Darurilor Înainte Sfințite</h3>
          <div class="space-y-2">
            {presanctifiedDays.map((day) => (
              <a
                href={`/presanctified/${toISODate(day.date)}`}
                class="block text-sm hover:text-rubric transition-colors"
              >
                <span class="text-stone-500">{day.formattedDate}</span>
                <span class="mx-1">·</span>
                <span class="text-stone-600">{day.dayOfWeek === "miercuri" ? "Miercuri" : "Vineri"}, Săpt. {day.lentWeek}</span>
                <span class="text-stone-400 ml-1">(gl. {day.tone})</span>
              </a>
            ))}
          </div>
        </div>
      </div>
    </details>
  </div>

  <script>
    // Calendar month show/hide
    const monthEls = document.querySelectorAll<HTMLElement>('.calendar-month');
    const titleEl = document.getElementById('month-title');
    const prevBtn = document.getElementById('prev-month');
    const nextBtn = document.getElementById('next-month');

    const MONTHS_RO = [
      "Ianuarie", "Februarie", "Martie", "Aprilie",
      "Mai", "Iunie", "Iulie", "August",
      "Septembrie", "Octombrie", "Noiembrie", "Decembrie",
    ];

    let currentMonth = new Date().getMonth(); // Default to current month

    function showMonth(m: number) {
      currentMonth = ((m % 12) + 12) % 12;
      monthEls.forEach(el => {
        el.classList.toggle('hidden', Number(el.dataset.month) !== currentMonth);
      });
      if (titleEl) titleEl.textContent = `${MONTHS_RO[currentMonth]} 2026`;
    }

    prevBtn?.addEventListener('click', () => showMonth(currentMonth - 1));
    nextBtn?.addEventListener('click', () => showMonth(currentMonth + 1));

    // Keyboard navigation
    document.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft') showMonth(currentMonth - 1);
      if (e.key === 'ArrowRight') showMonth(currentMonth + 1);
    });

    showMonth(currentMonth);
  </script>
</ServiceLayout>
